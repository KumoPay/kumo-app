{
  "name": "kumo",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first confidential cross-chain USDC payments. QVAC + MagicBlock PER + LI.FI + Solana durable nonces.",
  "scripts": {
    "dev": "pnpm --filter desktop dev",
    "mobile:start": "pnpm --filter mobile start",
    "mobile:android": "pnpm --filter mobile android",
    "mobile:typecheck": "pnpm --filter mobile typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "anchor:build": "cd programs/intent-receipt && anchor build",
    "anchor:test": "cd programs/intent-receipt && anchor test --skip-deploy"
  },
  "devDependencies": {
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "prettier": "^3.3.3",
    "tsx": "^4.21.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
