# --- Solana / RPC ---
HELIUS_API_KEY=
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# Helius devnet RPC — replace with your key
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=

# --- LI.FI ---
LIFI_API_KEY=
LIFI_INTEGRATOR=OffGridPay

# --- MagicBlock Private Payments ---
# Get from https://magicblock.app — session key signature challenge documented in lib/magicblock-pmts.ts
MAGICBLOCK_SESSION_KEY=
NEXT_PUBLIC_MAGICBLOCK_BASE_URL=https://payments.magicblock.app/v1

# --- QVAC (local LLM, OpenAI-compatible HTTP) ---
# User must run `qvac serve` in a separate terminal before starting the app
QVAC_BASE_URL=http://localhost:11434/v1
QVAC_MODEL=llama-3.2-1b-instruct

# --- Demo wallet (devnet only — DO NOT use mainnet keys) ---
# A base58-encoded secret key for the demo signer. Generate with:
#   solana-keygen new -o ./demo-keypair.json && cat ./demo-keypair.json
DEMO_WALLET_SECRET_KEY=
