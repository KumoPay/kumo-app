{
  "expo": {
    "name": "Kumo",
    "slug": "kumo-mobile",
    "scheme": "kumo",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "app.kumo.mobile",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0B1B3A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-background-task",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Kumo uses the camera to scan offline payment intents (QR codes) shared by other Kumo users."
        }
      ]
    ]
  }
}
