+  // Kumo patch: file extensions that need MediaExtractor decoding because
+  // the upstream `decodeWaveFile` only handles raw PCM-16 bytes. Matches the
+  // common MediaRecorder outputs on Android.
+  private static boolean isCompressedAudioPath(String path) {
+    if (path == null) return false;
+    String lower = path.toLowerCase();
+    int q = lower.indexOf('?');
+    if (q >= 0) lower = lower.substring(0, q);
+    return lower.endsWith(".m4a")
+        || lower.endsWith(".mp4")
+        || lower.endsWith(".aac")
+        || lower.endsWith(".mp3")
+        || lower.endsWith(".ogg")
+        || lower.endsWith(".opus")
+        || lower.endsWith(".webm")
+        || lower.endsWith(".3gp");
+  }
